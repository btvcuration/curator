{
  "manifest_version": 3,
  "name": "EUXP AI 큐레이터 연동기",
  "version": "1.0",
  "description": "AI Curator 데이터를 엑셀 다운로드 없이 EUXP 어드민에 바로 주입합니다.",
  "permissions": [
    "tabs"
  ],
  "host_permissions": [
    "https://euxp.skbroadband.com/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content_curator.js"]
    },
    {
      "matches": ["https://euxp.skbroadband.com/*"],
      "js": ["content_euxp.js"]
    }
  ]
}