{
  "manifest_version": 3,
  "name": "EUXP & RACE AI 큐레이터 연동기",
  "version": "3.0",
  "description": "AI Curator 데이터를 EUXP에 주입하고 RACE 블록명 변경 및 블록/레퍼런스 다중 빌드까지 원스톱으로 처리합니다.",
  "permissions": [
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://euxp.skbroadband.com/*",
    "http://1.255.152.46:5630/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content_curator.js"]
    },
    {
      "matches": ["https://euxp.skbroadband.com/*"],
      "js": ["content_euxp.js"]
    }
  ]
}
